bash .claude/skills/create-pr/check-changeset.sh > /tmp/changeset-check.txt 2>&1
result=$(cat /tmp/changeset-check.txt | head -1)

if [ "$result" = "CHANGESET_NEEDED" ]; then
  # src/ 변경이 있는 경우, 브랜치에 changeset 파일이 추가됐는지 확인
  has_changeset=$(git diff develop..HEAD --name-only 2>/dev/null | grep '^\.changeset/' | grep -v 'README\.md')

  if [ -z "$has_changeset" ]; then
    echo ""
    echo "❌ changeset이 필요합니다."
    echo ""
    echo "src/ 변경이 감지됐지만 changeset 파일이 없습니다."
    echo "아래 명령어를 실행한 뒤 다시 push하세요:"
    echo ""
    echo "  bun changeset"
    echo ""
    exit 1
  fi
fi

exit 0
